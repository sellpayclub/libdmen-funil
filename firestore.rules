rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && (request.auth.token.email == "personaldann@gmail.com" || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Analytics Event
    function isValidAnalyticsEvent(data) {
      return data.keys().hasAll(['sessionId', 'eventName', 'timestamp'])
        && data.keys().size() <= 4
        && data.sessionId is string && data.sessionId.size() <= 128
        && data.eventName is string && data.eventName.size() <= 128
        && data.timestamp == request.time
        && (data.keys().hasAll(['details']) ? data.details is string && data.details.size() <= 1024 : true);
    }

    match /analytics_events/{eventId} {
      // Anyone can create an event (unauthenticated tracking).
      allow create: if isValidId(eventId) && isValidAnalyticsEvent(request.resource.data);
      // Only admins can read
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Only manageable directly via Firebase Console
    }
  }
}
